// firestore.rules
// ─────────────────────────────────────────────────────────
// Paste these rules in Firebase Console:
// Firestore Database → Rules → Edit rules → Publish
// ─────────────────────────────────────────────────────────

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Anyone logged in can read doctors
    match /doctors/{doctorId} {
      allow read: if request.auth != null;
      allow write: if false; // Only writable via Firebase Console or admin
    }

    // Appointments:
    // - Patients can create and read their own appointments
    // - Doctors can read and update appointments assigned to them
    match /appointments/{appointmentId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null &&
                      (resource.data.patientUid == request.auth.uid ||
                       request.auth.token.role == 'doctor');
      allow update: if request.auth != null;
    }
  }
}
